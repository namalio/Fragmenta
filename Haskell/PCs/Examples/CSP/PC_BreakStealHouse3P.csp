BreakAndStealHouse = 
   let 
      GetInside = 
         let 
            GetInside0 = |~| x : MeansBreakIn @ break.x -> SKIP
         within
            GetInside0; (Ransack({}); getOutAndRun -> SKIP)
   within
      GetInside

Ransack(s) = 
   let 
      Steal(s) = |~| x : Stealable @ x == Other or not member (x, s) & steal.x -> Ransack(union (s, {x}))
   within
      SKIP
          |~| (Steal(s)
          |~| breakAndStealSafe -> Ransack(s))