StopPauseTimer(t) = 
   let 
      Paused = stopIt -> SKIP
            [] resume -> StopPauseTimer(t)
            [] tock -> Paused
   within
      if t >= 0
      then
         t > 0 & pause -> Paused
         [] t > 0 & tock -> StopPauseTimer(t - 1)
         [] t == 0 & timeout -> SKIP
         [] t > 0 & stopIt -> SKIP
      else
         STOP