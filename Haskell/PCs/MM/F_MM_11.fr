fragment F_MM_11 {
  SG SG_MM_11 {
    proxy PConnector
    node StartC
    proxy PStartN
    proxy PStartOfPC2
    inh StartC->PConnector
    derived StartC->PStartN[DSCSrc <-> src]:1;1
    derived StartC->PStartOfPC2[DSCTgt <-> tgt]:?;1
  }
  ref PConnector->Connector
  ref PStartN->StartN
  ref PStartOfPC2->StartOfPC
}
